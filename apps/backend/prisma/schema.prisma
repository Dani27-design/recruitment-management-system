generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMINISTRATOR
  MANAGER
}

enum VacancyStatus {
  ACTIVE
  INACTIVE
}

enum RecruitmentStageName {
  APPLIED
  SCREENING
  TECHNICAL_TEST
  INTERVIEW
  ACCEPTANCE
}

enum RecruitmentStageStatus {
  PENDING
  PASSED
  REJECTED
}

enum RecruitmentDocumentType {
  CV
  PORTFOLIO
}

enum AuditEventType {
  CREATE
  UPDATE
  DELETE
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          Role
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  recruitments  Recruitment[] @relation("RecruitmentCreator")
  assigned_stages RecruitmentStage[] @relation("StageAssignee")
  uploaded_documents RecruitmentDocument[] @relation("DocumentUploader")
  audit_logs AuditLog[] @relation("AuditActor")

  @@map("users")
}

model Candidate {
  id           String   @id @default(uuid())
  full_name    String
  email        String   @unique
  phone_number String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  recruitments Recruitment[]

  @@map("candidates")
}

model Vacancy {
  id            String        @id @default(uuid())
  position_name String
  department    String
  hiring_needed Int
  status        VacancyStatus
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  recruitments  Recruitment[]

  @@map("vacancies")
}

model Recruitment {
  id           String             @id @default(uuid())
  candidate_id String
  vacancy_id   String
  created_by   String
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  candidate    Candidate          @relation(fields: [candidate_id], references: [id])
  vacancy      Vacancy            @relation(fields: [vacancy_id], references: [id])
  creator      User               @relation("RecruitmentCreator", fields: [created_by], references: [id])
  stages       RecruitmentStage[]
  documents    RecruitmentDocument[]

  @@map("recruitments")
}

model RecruitmentStage {
  id               String                 @id @default(uuid())
  recruitment_id   String
  stage            RecruitmentStageName
  status           RecruitmentStageStatus
  assigned_user_id String?
  scheduled_at     DateTime?
  completed_at     DateTime?
  notes            String?
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt
  recruitment      Recruitment            @relation(fields: [recruitment_id], references: [id])
  assigned_user    User?                  @relation("StageAssignee", fields: [assigned_user_id], references: [id])

  @@unique([recruitment_id, stage])
  @@map("recruitment_stages")
}

model RecruitmentDocument {
  id                String                  @id @default(uuid())
  recruitment_id    String
  document_type     RecruitmentDocumentType
  original_filename String
  stored_filename   String
  mime_type         String
  file_size         Int
  storage_provider  String
  storage_path      String
  uploaded_by       String
  created_at        DateTime                @default(now())
  updated_at        DateTime                @updatedAt
  deleted_at        DateTime?
  recruitment       Recruitment             @relation(fields: [recruitment_id], references: [id])
  uploader          User                    @relation("DocumentUploader", fields: [uploaded_by], references: [id])

  @@map("recruitment_documents")
}

model AuditLog {
  id          String         @id @default(uuid())
  entity_type String
  entity_id   String
  event_type  AuditEventType
  actor_id    String
  changes     Json
  created_at  DateTime       @default(now())
  actor       User           @relation("AuditActor", fields: [actor_id], references: [id])

  @@map("audit_logs")
}
